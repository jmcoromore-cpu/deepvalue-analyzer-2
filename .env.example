# ============================================================
#  DeepValue Analyzer — variables de entorno
#  Copia este archivo a  .env  y rellena tus claves.
#  El archivo .env NUNCA se sube al repositorio (ver .gitignore)
# ============================================================

# --- Identidad para la SEC EDGAR (obligatorio para datos de EE.UU.) ---
# La SEC exige un identificador con tu correo real.
SEC_IDENTITY="TuNombre tu.correo@ejemplo.com"

# --- Google Gemini (para el veredicto cualitativo con IA) ---
# Consíguela gratis en https://aistudio.google.com/app/apikey
GEMINI_API_KEY=""
GEMINI_MODEL="gemini-1.5-flash"

# --- Alpha Vantage (opcional, complemento de precios/fundamentales) ---
# Gratis en https://www.alphavantage.co/support/#api-key
ALPHAVANTAGE_API_KEY=""

# --- Parámetros de análisis (valores por defecto) ---
DEFAULT_MARGIN_OF_SAFETY="0.20"     # 20 %
DEFAULT_DISCOUNT_RATE="0.09"        # WACC por defecto para el DCF
DEFAULT_TERMINAL_GROWTH="0.025"     # crecimiento a perpetuidad
QUANT_WEIGHT="0.55"                 # peso del pilar cuantitativo en el score
QUAL_WEIGHT="0.45"                  # peso del pilar cualitativo en el score

# --- CORS: orígenes permitidos para el frontend (separados por coma) ---
CORS_ORIGINS="http://localhost:5173,http://127.0.0.1:5173"

# --- Caché de datos (segundos) ---
CACHE_TTL="3600"
